---
import "@/styles/icons.css";

import { pages } from "@/configs/pages";
import {
  techAI,
  techBackend,
  techFrontend,
  techFullStack,
  techInfrastructure,
  techLanguages,
  techRuntimes,
  techTooling,
  titles,
  usageBadge,
} from "@/configs/tech";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";

const techSections = [
  { items: techLanguages, title: titles.languages },
  { items: techRuntimes, title: titles.runtimes },
  { items: techFullStack, title: titles.fullStack },
  { items: techFrontend, title: titles.frontend },
  { items: techTooling, title: titles.tooling },
  { items: techBackend, title: titles.backend },
  { items: techInfrastructure, title: titles.infrastructure },
  { items: techAI, title: titles.ai },
];
---

<BaseLayout
  title={pages.uses.title}
  description={pages.uses.description}
  keywords={pages.uses.keywords}
  alternates={[{ path: "/uses.md", type: "text/markdown" }]}
>
  <PageLayout heading={pages.uses.heading}>
    <article class="prose max-w-none prose-neutral dark:prose-invert">
      <p>
        What I use to build software, from the tools on my desk to the
        technologies I play with.
      </p>
      <ul>
        <li>
          <strong>Editor</strong>
          -
          <a
            href="https://code.visualstudio.com/"
            target="_blank"
            rel="noopener noreferrer">VS Code</a
          >
          or
          <a
            href="https://www.jetbrains.com/idea/"
            target="_blank"
            rel="noopener noreferrer">IntelliJ IDEA</a
          >, trying <a
            href="https://zed.dev/"
            target="_blank"
            rel="noopener noreferrer">Zed</a
          > and <a
            href="https://cursor.com/"
            target="_blank"
            rel="noopener noreferrer">Cursor</a
          >
        </li>
        <li>
          <strong>Terminal</strong>
          -
          <a
            href="https://ghostty.org/"
            target="_blank"
            rel="noopener noreferrer">Ghostty</a
          >
          with
          <a
            href="https://starship.rs/"
            target="_blank"
            rel="noopener noreferrer">Starship</a
          >
        </li>
        <li>
          <strong>AI Coding Agent</strong>
          -
          <a
            href="https://opencode.ai/"
            target="_blank"
            rel="noopener noreferrer">OpenCode</a
          >
        </li>
        <li>
          <strong>Laptop</strong>
          - MacBook Pro 16" M4 Max, 128GB RAM, 4TB SSD
        </li>
        <li><strong>Keyboard</strong> - HHKB Professional HYBRID Type-S</li>
        <li><strong>Mouse</strong> - Logitech MX Master 3S</li>
      </ul>
    </article>

    <hr />

    <section class="not-prose">
      <div class="mt-6 mb-6 flex flex-wrap justify-end gap-4">
        {
          Object.entries(usageBadge).map(([, { label, dot }]) => (
            <span class="flex items-center gap-1.5 text-xs text-muted">
              <span
                class:list={["inline-block h-2 w-2 shrink-0 rounded-full", dot]}
              />
              {label}
            </span>
          ))
        }
      </div>
      <div class="grid gap-10 sm:grid-cols-3" id="technologies">
        {
          techSections.map(({ title, items }) => (
            <div
              class="space-y-3"
              id={title.toLowerCase().replace(/\s+/g, "-")}
            >
              <h2 class="text-sm font-medium tracking-wider text-muted uppercase">
                {title}
              </h2>
              <ul class="not-prose space-y-2">
                {items.map((tech) => (
                  <li>
                    <a
                      href={tech.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-nowrap"
                    >
                      <span class:list={[tech.icon, "h-4 w-4 shrink-0"]} />
                      {tech.title}
                      {tech.ariaLabel && (
                        <span class="sr-only">
                          {" "}
                          {tech.ariaLabel.slice(tech.title.length)}
                        </span>
                      )}
                      <span
                        class:list={[
                          "inline-block h-2 w-2 shrink-0 rounded-full",
                          usageBadge[tech.usage].dot,
                        ]}
                      />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </PageLayout>
</BaseLayout>
