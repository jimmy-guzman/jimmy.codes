---
import { pages } from "@/configs/pages";
import { urls } from "@/configs/urls";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";
---

<BaseLayout
  title={pages.home.title}
  description={pages.home.description}
  keywords={pages.home.keywords}
>
  <PageLayout heading={pages.home.heading}>
    <section class="space-y-12">
      <p class="leading-relaxed">
        I'm a <a href="/about">staff+ engineer</a> with a passion for the craft of
        software. I build systems engineers love and architectures that make a lasting
        impact.
      </p>
    </section>

    <section>
      <p>
        I work across the full stack, mostly <a href="/uses#languages"
          >TypeScript</a
        >, <a href="/uses#frontend">React</a>, and <a href="/uses#runtimes"
          >Node.js</a
        > on the frontend and backend, with <a href="/uses#languages">Kotlin</a> and
        <a href="/uses#backend">Ktor</a> when the JVM makes sense. I reach for <a
          href="/uses#full-stack">Next.js or TanStack Start</a
        > for full-stack apps, and <a href="/uses#backend"
          >Postgres, Redis, and Kafka</a
        > for the data layer.
      </p>
    </section>

    <section class="space-y-6">
      <p>
        Connect via <a
          href={urls.GitHub}
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >, <a href={urls.LinkedIn} target="_blank" rel="noopener noreferrer"
          >LinkedIn</a
        >, or <a href={urls.email}>email</a>. Check out my <a href="/blog"
          >blog</a
        > too.
      </p>
    </section>
  </PageLayout>
</BaseLayout>
