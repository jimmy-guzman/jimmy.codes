---
import { pages } from "@/configs/pages";
import { urls } from "@/configs/urls";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";
---

<BaseLayout
  title={pages.home.title}
  description={pages.home.description}
  keywords={pages.home.keywords}
>
  <PageLayout heading={pages.home.heading}>
    <section class="space-y-12">
      <p class="leading-relaxed">
        I'm a <a href="/about">staff+ engineer</a> with a passion for the craft of
        software. I build systems engineers love and architectures that make a lasting
        impact.
      </p>
    </section>

    <section>
      <p>
        I work across the full stack, mostly <a
          href="https://www.typescriptlang.org/"
          target="_blank"
          rel="noopener noreferrer">TypeScript</a
        >, <a
          href="https://react.dev/"
          target="_blank"
          rel="noopener noreferrer">React</a
        >, and <a
          href="https://nodejs.org/"
          target="_blank"
          rel="noopener noreferrer">Node.js</a
        > on the frontend and backend, with <a
          href="https://kotlinlang.org/"
          target="_blank"
          rel="noopener noreferrer">Kotlin</a
        > and <a
          href="https://ktor.io/"
          target="_blank"
          rel="noopener noreferrer">Ktor</a
        > when the JVM makes sense. I reach for <a
          href="https://nextjs.org/"
          target="_blank"
          rel="noopener noreferrer">Next.js</a
        > or <a
          href="https://tanstack.com/start"
          target="_blank"
          rel="noopener noreferrer">TanStack Start</a
        > for full-stack apps, and <a
          href="https://www.postgresql.org/"
          target="_blank"
          rel="noopener noreferrer">Postgres</a
        >, <a href="https://redis.io/" target="_blank" rel="noopener noreferrer"
          >Redis</a
        >, and <a
          href="https://kafka.apache.org/"
          target="_blank"
          rel="noopener noreferrer">Kafka</a
        > for the data layer.
      </p>
    </section>

    <section class="space-y-6">
      <p>
        <a href="/about">Learn about me</a> or see what I <a href="/uses">use</a
        > or check out my <a href="/blog">blog</a>.
      </p>
      <p>
        Connect via <a
          href={urls.GitHub}
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >, <a href={urls.LinkedIn} target="_blank" rel="noopener noreferrer"
          >LinkedIn</a
        >, or <a href={urls.email}>email</a>.
      </p>
    </section>
  </PageLayout>
</BaseLayout>
