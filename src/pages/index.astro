---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import { sortByPublishDate } from "@/utils/content";
import { shortTitle } from "@/utils/post";

const posts = await getCollection("posts");
const latestPost = posts.sort(sortByPublishDate)[0];

const page = await getEntry("pages", "home");

if (!page) throw new Error("Missing content: pages/home.md");

const { Content } = await render(page);
---

<BaseLayout
  title={page.data.title}
  description={page.data.description}
  keywords={page.data.keywords}
  alternates={[{ path: "/index.md", type: "text/markdown" }]}
>
  <PageLayout heading={page.data.heading}>
    <Content />
    <p>
      Latest post:
      <a href={`/blog/${latestPost.id}`} rel="bookmark" data-astro-prefetch
        >{shortTitle(latestPost)}</a
      >.
    </p>
  </PageLayout>
</BaseLayout>
