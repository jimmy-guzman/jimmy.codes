---
import { getCollection, render } from "astro:content";

import { BASE_TITLE } from "@/configs/pages";
import { urls } from "@/configs/urls";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentLayout from "@/layouts/ContentLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import { lastModified, readingTime } from "@/utils/content";
import { shortTitle } from "@/utils/post";
import { getRelatedByTags } from "@/utils/related";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => {
    const updatedDate =
      post.data.updatedDate ??
      (post.filePath ? lastModified(post.filePath) : undefined);

    const relatedPosts = getRelatedByTags(posts, post, {
      limit: 3,
      recencyWeight: 0.02,
    });
    const base = { post, relatedPosts, updatedDate };

    return { params: { slug: post.id }, props: base };
  });
}

const { post, relatedPosts, updatedDate } = Astro.props;

const { Content } = await render(post);

const postBody = post.body ?? "";
const postUrl = `${urls.site}/blog/${post.id}`;
const minutes = readingTime(postBody);
const wordCount = postBody.trim().split(/\s+/).filter(Boolean).length;
const datePublished = post.data.publishDate;
const dateModified = updatedDate ?? datePublished;
const timeRequired = `PT${Math.max(1, Math.round(minutes))}M`;
const description = post.data.description;
const keywords = post.data.keywords;
const tags = post.data.tags.map((tag) => ({ count: 1, tag }));
const ogImage = `/og/blog/${post.id}.png`;
const jsonLd = {
  "@id": `${postUrl}#article`,
  "@type": "BlogPosting",
  "author": { "@id": `${urls.site}/#person` },
  dateModified,
  datePublished,
  description,
  "headline": post.data.title,
  "image": {
    "@type": "ImageObject",
    "height": 630,
    "url": `${urls.site}${ogImage}`,
    "width": 1200,
  },
  "inLanguage": "en-US",
  "isAccessibleForFree": true,
  keywords,
  "mainEntityOfPage": { "@id": `${postUrl}#webpage` },
  "publisher": { "@id": `${urls.site}/#person` },
  timeRequired,
  "url": postUrl,
  wordCount,
};
const heading = shortTitle(post);
const backOptions = { title: "blog" as const, url: "/blog" };
const article = {
  modifiedTime: dateModified,
  publishedTime: datePublished,
  tags: post.data.tags,
};
---

<BaseLayout
  title={`${post.data.title} | ${BASE_TITLE}`}
  description={description}
  keywords={keywords}
  extraLd={[jsonLd]}
  ogImage={ogImage}
  ogType="article"
  article={article}
  alternates={[{ path: `/blog/${post.id}.md`, type: "text/markdown" }]}
>
  <PageLayout heading={heading} back={backOptions}>
    <ContentLayout
      title={heading}
      tags={tags}
      publishDate={datePublished}
      updatedDate={updatedDate}
      minutes={minutes}
      filePath={post.filePath}
      relatedPosts={relatedPosts}
      slug={post.id}
    >
      <Content />
    </ContentLayout>
  </PageLayout>
</BaseLayout>
