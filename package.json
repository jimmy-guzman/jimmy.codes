{
  "name": "jimmy.codes",
  "private": true,
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "build:resume": "pandoc public/resume.md -o public/resume.pdf --pdf-engine=xelatex -V geometry:margin=0.85in -V fontsize=11pt -V mainfont=\"Arial\"",
    "check": "bun run --sequential knip lint build typecheck coverage",
    "coverage": "vitest run --coverage",
    "deps:dedupe": "rm -rf node_modules && rm bun.lock && bun install",
    "deps:up": "bunx npm-check-updates -ui",
    "dev": "bunx --bun astro dev",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "fix:lint": "bun run --parallel 'fix:lint:*'",
    "fix:lint:biome": "biome lint --fix .",
    "fix:lint:md": "markdownlint --fix \"src/content/**/*.{md,mdx}\"",
    "fmt": "bun run --parallel 'fmt:*'",
    "fmt:biome": "biome format --write .",
    "fmt:prettier": "prettier --experimental-cli --write \"**/*.{astro,md,mdx}\" --ignore-path .gitignore",
    "knip": "KNIP=true knip",
    "lint": "bun run --parallel 'lint:*'",
    "lint:biome": "biome lint .",
    "lint:md": "markdownlint \"src/content/**/*.{md,mdx}\"",
    "prepare": "is-ci || lefthook install",
    "preview": "astro preview",
    "test": "vitest",
    "typecheck": "tsc && astro check"
  },
  "overrides": {
    "sharp": "$sharp"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/vercel": "10.0.1",
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@iconify-json/devicon": "1.2.61",
    "@iconify-json/logos": "1.2.10",
    "@iconify-json/lucide": "1.2.98",
    "@iconify-json/simple-icons": "1.2.74",
    "@iconify-json/skill-icons": "1.2.4",
    "@iconify/tailwind4": "1.2.3",
    "@playwright/test": "1.58.2",
    "@shikijs/colorized-brackets": "4.0.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.10",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@vercel/og": "0.11.1",
    "@vitest/coverage-v8": "4.1.0",
    "astro": "6.1.1",
    "astro-expressive-code": "0.41.7",
    "astro-favicons": "3.1.6",
    "daisyui": "5.5.19",
    "expressive-code-twoslash": "0.6.1",
    "gitzy": "6.5.9",
    "hastscript": "9.0.1",
    "is-ci": "4.1.0",
    "knip": "5.88.0",
    "lefthook": "2.1.4",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react": "19.2.4",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-callouts": "2.1.2",
    "rehype-external-links": "3.0.0",
    "rehype-slug": "6.0.0",
    "rehype-unwrap-images": "1.0.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.1",
    "tailwindcss-safe-area": "1.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "yaml": "2.8.2"
  },
  "packageManager": "bun@1.3.11",
  "gitzy": {
    "useCommitlintConfig": true
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "lefthook",
    "sharp"
  ]
}
